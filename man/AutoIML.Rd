}

\subsection{Arguments}{
\if{html}{\out{<div class="arguments">}}
\describe{
\item{\code{row_id}}{(\code{integer(1)} | \code{character(1)})
Row id of the observation to explain (must exist in \code{task}).}

\item{\code{class_label}}{(\code{character(1)} | \code{NULL})
For classification tasks, the class to explain. Defaults to the first
